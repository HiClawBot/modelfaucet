NODE_ENV=development
PORT_API=3001
PORT_GATEWAY=3002
DATABASE_URL=postgresql://modelfaucet:modelfaucet@localhost:5432/modelfaucet
REDIS_URL=redis://localhost:6379

JWT_SECRET=dev_only_replace_me
ADMIN_TOKEN=mf_admin_dev
# Bootstrap/operator only. Use POST /v1/developer/tokens to create scoped mf_dev_ tokens for production developer access.
DEVELOPER_ADMIN_TOKEN=mf_admin_dev
SESSION_TOKEN_TTL_SECONDS=3600
API_RATE_LIMIT_MAX_REQUESTS=1200
API_RATE_LIMIT_WINDOW_MS=60000
# Comma-separated origins. Required in production; development may omit for demo CORS.
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-litellm-dev-master-key
PROVIDER_TIMEOUT_MS=30000
PROVIDER_MAX_RETRIES=1
PROVIDER_RETRY_DELAY_MS=250
GATEWAY_RATE_LIMIT_MAX_REQUESTS=1200
GATEWAY_RATE_LIMIT_WINDOW_MS=60000
# Comma-separated origins. Required in production; development may omit for demo CORS.
GATEWAY_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

VITE_MODELFAUCET_API_BASE_URL=http://localhost:3001
VITE_MODELFAUCET_GATEWAY_BASE_URL=http://localhost:3002/v1
# Do not set VITE_MODELFAUCET_DEVELOPER_TOKEN or VITE_MODELFAUCET_DEVELOPER_ADMIN_TOKEN in public hosted dashboard builds.

# Server-side only. Never expose to SDK/client bundles.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Dev mode only. Production must use KMS/Vault/Secret Manager.
SECRET_ENCRYPTION_KEY=dev_32_bytes_replace_me_replace_me

# Stripe test mode, optional for phase 5.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

PAYOUT_THRESHOLD_USD=1.00000000
