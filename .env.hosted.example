# ModelFaucet hosted beta environment template.
# Keep real values in a secret manager or private deployment environment, never in git.

NODE_ENV=production
HOSTED_ENVIRONMENT=staging
HOSTED_SECRET_MANAGER=example-secret-manager

# Public HTTPS endpoints used for CORS, links, and smoke checks.
API_PUBLIC_BASE_URL=https://api.modelfaucet.example
GATEWAY_PUBLIC_BASE_URL=https://gateway.modelfaucet.example/v1
DASHBOARD_PUBLIC_BASE_URL=https://dashboard.modelfaucet.example
PUBLIC_SUPPORT_URL=https://modelfaucet.example/support

# Database and internal service URLs.
DATABASE_URL=
LITELLM_BASE_URL=https://litellm.modelfaucet.example

# Required server-side secrets. Do not put these in browser-visible Vite env vars.
# DEVELOPER_ADMIN_TOKEN is bootstrap/operator only; create scoped mf_dev_ tokens for production developer workflows.
SECRET_ENCRYPTION_KEY=
ADMIN_TOKEN=
DEVELOPER_ADMIN_TOKEN=
LITELLM_MASTER_KEY=

# Explicit production CORS allowlists. Do not use '*'.
API_CORS_ORIGINS=https://dashboard.modelfaucet.example,https://crm-demo.modelfaucet.example
GATEWAY_CORS_ORIGINS=https://crm-demo.modelfaucet.example

# Provider keys are server-side only and optional until real provider pilot traffic starts.
REQUIRE_HOSTED_PROVIDER=0
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Stripe keys are server-side only and optional until hosted Stripe top-ups are enabled.
REQUIRE_HOSTED_STRIPE=0
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public contact paths required before hosted pilot onboarding.
SECURITY_CONTACT_EMAIL=security@modelfaucet.example
ABUSE_CONTACT_EMAIL=abuse@modelfaucet.example
INCIDENT_CONTACT_EMAIL=incident@modelfaucet.example

# Operational policy defaults.
PAYOUT_THRESHOLD_USD=25.00000000
API_RATE_LIMIT_MAX_REQUESTS=1200
API_RATE_LIMIT_WINDOW_MS=60000
GATEWAY_RATE_LIMIT_MAX_REQUESTS=1200
GATEWAY_RATE_LIMIT_WINDOW_MS=60000
PROVIDER_TIMEOUT_MS=30000
PROVIDER_MAX_RETRIES=1
PROVIDER_RETRY_DELAY_MS=250
